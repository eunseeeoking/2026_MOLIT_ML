{
  "name": "molit-ml",
  "private": true,
  "version": "0.1.0",
  "description": "2026 MOLIT Contest - LSTM training pipeline (separated repo)",
  "type": "commonjs",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "train": "tsx src/train.ts",
    "train:one": "tsx src/train.ts --once",
    "backtest:run": "tsx src/backtest/run.ts",
    "backtest:arima": "python scripts/backtest/arima.py",
    "backtest:visualize": "python scripts/backtest/visualize.py",
    "backtest:all": "npm run backtest:run && npm run backtest:arima && npm run backtest:visualize",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@tensorflow/tfjs": "^4.20.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "prisma": "^5.15.0",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
